# AI Provider: "openai", "gemini", or "vertex"
AI_PROVIDER=vertex
CONTENT_MODEL=gemini-2.5-flash

# OpenAI (if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Google Gemini (if AI_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key

# Vertex AI (if AI_PROVIDER=vertex)
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=europe-west9
GOOGLE_SERVICE_ACCOUNT_PATH=credentials/your-service-account.json
# For cloud deployment (Render, etc.) — paste the full JSON content:
GOOGLE_SERVICE_ACCOUNT_JSON=

# Freework Credentials
FREEWORK_EMAIL=your-email@example.com
FREEWORK_PASSWORD=your-password
# Session cookies (optional — auto-populated after first login)
FREEWORK_JWT_HP=
FREEWORK_JWT_S=
FREEWORK_REFRESH_TOKEN=

# Freelancer Profile
FREELANCER_NAME=John Doe
FREELANCER_FIRST_NAME=John
FREELANCER_LAST_NAME=Doe
FREELANCER_TITLE=Data Analyst
FREELANCER_EMAIL=john.doe@example.com
FREELANCER_PHONE=+33 6 00 00 00 00
FREELANCER_LINKEDIN=https://www.linkedin.com/in/johndoe/
FREELANCER_GITHUB=
FREELANCER_SKILLS=["Power BI","SQL","Python","Tableau"]
DAILY_RATE_MIN=450
PREFERRED_LOCATIONS=["France","Ile-de-France"]
REMOTE_ONLY=false
LANGUAGES=["French","English"]
SEARCH_QUERIES=["Data Analyst","BI Consultant","Power BI Developer"]

# Resumes (absolute paths to PDF files)
RESUME_FR=
RESUME_EN=

# Database (SQLite Cloud — leave empty for local SQLite fallback)
SQLITE_CLOUD_URL=sqlitecloud://your-node.sqlite.cloud:8860/your-database?apikey=your-api-key

# Scanning
SCAN_INTERVAL_MINUTES=30
RELEVANCE_THRESHOLD=70
